                        "nickname": "小刘头发疯长",
                        "avatar": "https://sns-avatar-qc.xhscdn.com/avatar/1040g2jo30r3nnept1g6g5pa3i9d0rs4mjhvrol0",
                        "xsecToken": "ABglek98bOZJ2AVfkS1-rXcVwGxiuIH5fuEAIYEWfAJwY="
                    },
                    "interactInfo": {
                        "shareCount": "10+",
                        "followed": false,
                        "relation": "none",
                        "liked": false,
                        "likedCount": "10+",
                        "collected": false,
