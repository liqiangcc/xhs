                    "type": "normal",
                    "title": "🔥 电网Java项目技术面试｜2轮核心考点+避坑",
                    "user": {
                        "userId": "63572290000000001901d19a",
                        "nickname": "程序员峰哥",
                        "avatar": "https://sns-avatar-qc.xhscdn.com/avatar/63572290000000001901d19a.jpg",
                        "xsecToken": "ABvITRtt5SMxi3NH_p3BuuXNmqKPrv1V7EQ0Y1MqDtt1w="
                    },
                    "interactInfo": {
                        "collected": false,
                        "collectedCount": "10+",
                        "commentCount": "1",
