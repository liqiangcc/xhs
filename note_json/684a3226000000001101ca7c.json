                "currentTime": 1766837232806,
                "note": {
                    "xsecToken": "ABeieMnYECixRnk8gieekjW5zn5N4iiR562l1onbi706U=",
                    "lastUpdateTime": 1750091697000,
                    "shareInfo": {
                        "unShare": false
