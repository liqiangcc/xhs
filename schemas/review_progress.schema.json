{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xhs.local/schemas/review_progress.schema.json",
  "title": "ReviewProgress",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "canonical_id",
    "status",
    "review_count",
    "last_reviewed_at",
    "next_review_at",
    "confidence",
    "difficulty",
    "mistake_count",
    "updated_at"
  ],
  "properties": {
    "canonical_id": {
      "type": "string",
      "pattern": "^cq_[a-z0-9_]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "learning",
        "weak",
        "mastered",
        "archived"
      ]
    },
    "review_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_reviewed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_review_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mistake_count": {
      "type": "integer",
      "minimum": 0
    },
    "updated_at": {
      "type": "string"
    }
  }
}
