{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xhs.local/schemas/review_progress.schema.json",
  "title": "ReviewProgressStore",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "updated_at",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "review_progress_store.v1"
      ]
    },
    "updated_at": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "canonical_id",
          "status",
          "level",
          "review_count",
          "last_reviewed_at",
          "next_review_at",
          "confidence",
          "difficulty",
          "mistake_count",
          "updated_at"
        ],
        "properties": {
          "canonical_id": {
            "type": "string",
            "pattern": "^cq_[a-z0-9_]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "learning",
              "weak",
              "mastered",
              "archived"
            ]
          },
          "level": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "review_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_reviewed_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "next_review_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "difficulty": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "mistake_count": {
            "type": "integer",
            "minimum": 0
          },
          "updated_at": {
            "type": "string"
          }
        }
      }
    }
  }
}
