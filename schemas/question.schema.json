{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xhs.local/schemas/question.schema.json",
  "title": "Question",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "question_id",
    "original_question",
    "source_note_id",
    "company",
    "position",
    "round",
    "level",
    "year",
    "date",
    "domain",
    "question_type",
    "cognitive_depth",
    "tech_entities",
    "business_context",
    "is_valid_for_library",
    "canonical_id",
    "schema_version",
    "taxonomy_version"
  ],
  "properties": {
    "question_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "original_question": {
      "type": "string"
    },
    "source_note_id": {
      "type": "string"
    },
    "source_question_index": {
      "type": "integer",
      "minimum": 0
    },
    "company": {
      "type": "string"
    },
    "position": {
      "type": "string"
    },
    "round": {
      "type": "string"
    },
    "level": {
      "type": "string"
    },
    "year": {
      "type": [
        "string",
        "number"
      ]
    },
    "date": {
      "type": [
        "string",
        "number"
      ]
    },
    "domain": {
      "type": "object",
      "required": [
        "l1",
        "l2"
      ],
      "properties": {
        "l1": {
          "type": "string"
        },
        "l2": {
          "type": "string"
        }
      }
    },
    "question_type": {
      "type": "string"
    },
    "cognitive_depth": {
      "type": "string"
    },
    "tech_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "business_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "is_valid_for_library": {
      "type": "boolean"
    },
    "canonical_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "question.v1"
      ]
    },
    "taxonomy_version": {
      "type": "string",
      "enum": [
        "taxonomy.v1"
      ]
    }
  }
}
