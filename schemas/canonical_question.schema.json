{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xhs.local/schemas/canonical_question.schema.json",
  "title": "CanonicalQuestion",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "canonical_id",
    "canonical_title",
    "aliases",
    "question_ids",
    "primary_domain",
    "primary_entities",
    "companies",
    "frequency",
    "review_priority",
    "answer_status",
    "schema_version"
  ],
  "properties": {
    "canonical_id": {
      "type": "string",
      "pattern": "^cq_[a-z0-9_]+$"
    },
    "canonical_title": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{32}$"
      }
    },
    "primary_domain": {
      "type": "object",
      "required": [
        "l1",
        "l2"
      ],
      "properties": {
        "l1": {
          "type": "string"
        },
        "l2": {
          "type": "string"
        }
      }
    },
    "primary_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "companies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frequency": {
      "type": "integer",
      "minimum": 0
    },
    "review_priority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "answer_status": {
      "type": "string",
      "enum": [
        "missing",
        "draft",
        "ready",
        "needs_update"
      ]
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "canonical_question.v1"
      ]
    }
  }
}
